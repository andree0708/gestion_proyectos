generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:lucas1234@127.0.0.1:5433/subpro?schema=public"
}

enum KybStatus {
  pending
  approved
  rejected
}

enum Plan {
  free
  premium
}

enum UserRole {
  admin
  moderator
  buyer
  seller
}

enum ListingStatus {
  draft
  pending_review
  active
  rejected
}

enum PriceType {
  fixed
  negotiate
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  taxId       String   @map("tax_id")
  country     String
  sector      String
  kybStatus   KybStatus @default(pending) @map("kyb_status")
  plan        Plan     @default(free)
  kybDocs     Json?    @map("kyb_docs")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users     User[]
  listings  Listing[]
  offers    Offer[]    @relation("BuyerOffers")
  ordersAsSeller Order[] @relation("SellerOrders")
  ordersAsBuyer  Order[] @relation("BuyerOrders")
  shipments Shipment[] @relation("CarrierShipments")

  @@map("organizations")
}

model User {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  email       String   @unique
  password    String
  fullName    String   @map("full_name")
  role        UserRole @default(seller)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  level     Int
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id              String        @id @default(uuid())
  orgId           String        @map("org_id")
  categoryId      String        @map("category_id")
  title           String
  description     String?
  quantity        Decimal       @db.Decimal(12, 2)
  unit            String
  priceType       PriceType     @map("price_type") @default(fixed)
  priceAmount     Decimal?      @map("price_amount") @db.Decimal(12, 2)
  attributes      Json?
  status          ListingStatus @default(draft)
  photos          String[]
  technicalSheetUrl String?     @map("technical_sheet_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  offers      Offer[]

  @@map("listings")
}

model Offer {
  id            String    @id @default(uuid())
  listingId     String    @map("listing_id")
  buyerOrgId    String    @map("buyer_org_id")
  quantity      Decimal   @db.Decimal(12, 2)
  unitPrice     Decimal   @map("unit_price") @db.Decimal(12, 2)
  message       String?
  status        String    @default("pending")
  parentOfferId String?   @map("parent_offer_id")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  listing   Listing      @relation(fields: [listingId], references: [id])
  buyer     Organization @relation("BuyerOffers", fields: [buyerOrgId], references: [id])
  parent    Offer?       @relation("OfferChain", fields: [parentOfferId], references: [id])
  children  Offer[]      @relation("OfferChain")
  order     Order?

  @@map("offers")
}

model Order {
  id            String   @id @default(uuid())
  offerId       String   @unique @map("offer_id")
  sellerOrgId   String   @map("seller_org_id")
  buyerOrgId    String   @map("buyer_org_id")
  status        String   @default("pending")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  platformFee   Decimal  @map("platform_fee") @db.Decimal(12, 2)
  netAmount     Decimal  @map("net_amount") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  offer      Offer        @relation(fields: [offerId], references: [id])
  seller     Organization @relation("SellerOrders", fields: [sellerOrgId], references: [id])
  buyer      Organization @relation("BuyerOrders", fields: [buyerOrgId], references: [id])
  shipment   Shipment?
  payment    Payment?
  contract   Contract?
  conversation Conversation?

  @@map("orders")
}

model Shipment {
  id              String   @id @default(uuid())
  orderId         String   @unique @map("order_id")
  carrierOrgId    String   @map("carrier_org_id")
  trackingCode    String?  @map("tracking_code")
  status          String   @default("pending")
  estimatedDelivery DateTime? @map("estimated_delivery")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order       Order          @relation(fields: [orderId], references: [id])
  carrier    Organization    @relation("CarrierShipments", fields: [carrierOrgId], references: [id])
  events     ShipmentEvent[]

  @@map("shipments")
}

model ShipmentEvent {
  id          String   @id @default(uuid())
  shipmentId  String   @map("shipment_id")
  status      String
  location    String?
  timestamp   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@map("shipment_events")
}

model Payment {
  id                  String   @id @default(uuid())
  orderId             String   @unique @map("order_id")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  amount              Decimal  @db.Decimal(12, 2)
  currency            String   @default("COP")
  status              String   @default("pending")
  escrowReleasedAt    DateTime? @map("escrow_released_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Contract {
  id          String   @id @default(uuid())
  orderId     String   @unique @map("order_id")
  contentHash String   @map("content_hash")
  pdfUrl      String?  @map("pdf_url")
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  order      Order              @relation(fields: [orderId], references: [id])
  signatures ContractSignature[]

  @@map("contracts")
}

model ContractSignature {
  id          String   @id @default(uuid())
  contractId  String   @map("contract_id")
  signerId    String   @map("signer_id")
  signerOrgId String   @map("signer_org_id")
  signature   String
  timestamp   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])

  @@map("contract_signatures")
}

model Conversation {
  id        String   @id @default(uuid())
  orderId   String?  @unique @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order    Order?      @relation(fields: [orderId], references: [id])
  messages Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")
  userId         String @map("user_id")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  attachments    String[]
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

model Review {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  reviewerOrgId String   @map("reviewer_org_id")
  reviewedOrgId String   @map("reviewed_org_id")
  rating        Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([orderId, reviewerOrgId])
  @@map("reviews")
}

model Alert {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  categoryId String?  @map("category_id")
  region     String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("alerts")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  payload      Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}